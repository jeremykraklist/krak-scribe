# Auth
JWT_SECRET=change-me-to-a-random-string

# OpenRouter API (for AI processing templates)
OPENROUTER_API_KEY=your-openrouter-api-key-here

# Database
DATABASE_URL=./data/krak-scribe.db

# Server
PORT=3200
NODE_ENV=production

# Whisper.cpp (local transcription)
# Path to whisper-cli binary
WHISPER_CLI=/opt/whisper.cpp/build/bin/whisper-cli
# Path to whisper model file (see README for model options)
WHISPER_MODEL=/opt/whisper.cpp/models/ggml-medium.en.bin
# Number of CPU threads for transcription
WHISPER_THREADS=4
